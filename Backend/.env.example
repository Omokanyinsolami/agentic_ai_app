# Database settings (required)
DB_NAME=agentic_academic_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432
DB_CONNECT_TIMEOUT=5
DB_SSLMODE=require
DB_ADMIN_DB=postgres

# App runtime
FLASK_DEBUG=false
PORT=5000
SESSION_TTL_HOURS=12
CORS_ORIGINS=http://localhost:3000
REMINDER_LOOKAHEAD_DAYS=5

# Optional: Groq API key for LLM-backed reasoning/scheduling
# Used for natural-language understanding, advice generation,
# schedule reasoning, and adaptation explanations.
# Without this key, the app still runs but falls back to simpler rule-based behaviour.
GROQ_API_KEY=gsk_your_api_key_here

# Optional: Email notifications
# For free-host deployment, prefer Brevo API over SMTP:
# EMAIL_PROVIDER=brevo
# BREVO_API_KEY=your_brevo_api_key
# BREVO_FROM_EMAIL=your_verified_sender@example.com
# BREVO_FROM_NAME=Agentic AI Prototype
#
# For local/dev SMTP instead:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=your_email@gmail.com
# SMTP_USE_TLS=true
